# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ─── Modèles propp-fr (téléchargés automatiquement au 1er lancement) ───
AntoineBourgois/

# ─── Artefacts générés ────────────────────────────────────
coref.html
*.log
srv*.log

# ─── Secrets (ne jamais committer) ────────────────────────
.mistral_key
*.key
.env

# ─── Anciens essais (non liés à l'app) ────────────────────
outputs_old/

# ─── Éditeurs / IDE ───────────────────────────────────────
.vscode/
.idea/
.claude/
**/.DS_Store

# ─── Flutter / Dart (régénéré par `flutter pub get` / build) ───
picto_express/build/
picto_express/.dart_tool/
picto_express/.flutter-plugins
picto_express/.flutter-plugins-dependencies
picto_express/.packages
picto_express/.metadata

